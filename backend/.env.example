# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — Copy this file to .env and fill in the real values.
#  NEVER commit .env to Git!
#  On Koyeb, set these as "App Secrets" in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Neon PostgreSQL (get all values from your Neon project dashboard) ─────────
DB_URL=jdbc:postgresql://<host>/<dbname>?sslmode=require
DB_USERNAME=<your-neon-username>
DB_PASSWORD=<your-neon-password>

# ── JWT secret — generate a long random string (min 32 chars) ─────────────────
JWT_SECRET=replace_with_a_very_long_random_secret_string_minimum_32_chars

# ── Admin email (OTP will be sent here) ───────────────────────────────────────
ADMIN_EMAIL=tsribatsapatro@gmail.com

# ── Gmail SMTP (for OTP emails and newsletters) ───────────────────────────────
MAIL_USERNAME=youremail@gmail.com
MAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Frontend URL (for blog notification emails) ───────────────────────────────
# Local dev:   http://localhost:5173
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Frontend env var (set in Vercel dashboard → Project Settings → Env Variables)
# VITE_API_URL=https://your-koyeb-app.koyeb.app/api
